generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  RESTAURANT_ADMIN
  CASHIER
  WAITER
}

model Restaurant {
  id               String           @id
  name             String
  mobileNumber     String?
  isActive         Boolean          @default(true)
  users            User[]
  customers        Customer[]
  suppliers        Supplier[]
  menuCategories   MenuCategory[]
  menuItems        MenuItem[]
  variants         Variant[]
  addons           Addon[]
  itemCategories   ItemCategory[]
  itemSubCategories ItemSubCategory[]
  brands           Brand[]
  inventoryItems   InventoryItem[]
  purchases        Purchase[]
  expenses         Expense[]
  orders           Order[]
  registers        Register[]
  registerSessions CashierRegisterSession[]
  inventoryMovements InventoryMovement[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

enum ExpenseCategory {
  CLEANING
  DEFAULT
  INSTALLMENTS
  KITCHEN
  MARKETING
  STAFF_SALARY
  STAFF_UTILITY
  UTILITY
}

enum ExpensePaymentMethod {
  CASH
  CREDIT
  BANK_TRANSFER
  UPI
  CARD
  OTHER
}

model Expense {
  id              String               @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  expenseDate     DateTime
  refNo           String?
  payeeName       String?
  description     String?
  category        ExpenseCategory
  paymentMethod   ExpensePaymentMethod
  amount          Decimal              @db.Decimal(12, 2)
  createdByUserId String
  createdBy       User                 @relation("ExpenseCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model User {
  id               String           @id @default(cuid())
  name             String
  passwordHash     String
  role             Role
  isActive         Boolean          @default(true)
  restaurantId     String?
  restaurant       Restaurant?      @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  refreshSessions  RefreshSession[]
  purchasesCreated Purchase[]       @relation("PurchaseCreator")
  expensesCreated  Expense[]        @relation("ExpenseCreator")
  ordersPlaced     Order[]          @relation("OrderPlacedBy")
  ordersReceived   Order[]          @relation("OrderReceivedBy")
  ordersWasted     Order[]          @relation("OrderWastedBy")
  registerSessions CashierRegisterSession[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([restaurantId, name])
}

model RefreshSession {
  id                  String          @id @default(cuid())
  userId              String
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash           String          @unique
  expiresAt           DateTime
  revokedAt           DateTime?
  replacedBySessionId String?         @unique
  replacedBySession   RefreshSession? @relation("SessionRotation", fields: [replacedBySessionId], references: [id], onDelete: SetNull)
  previousSession     RefreshSession? @relation("SessionRotation")
  createdAt           DateTime        @default(now())
}

model Customer {
  id           String     @id @default(cuid())
  name         String
  mobileNumber String
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders       Order[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, mobileNumber])
}

model Supplier {
  id            String     @id @default(cuid())
  name          String
  contactNumber String
  description   String?
  restaurantId  String
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  purchases     Purchase[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

enum InventoryUnit {
  PCS
  KG
  L
}

enum PurchasePaymentMethod {
  CASH
  CREDIT
}

enum VariantCategory {
  SIZE
}

enum MenuType {
  DINEIN
  TAKE_AWAY
}

model MenuCategory {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  status       Boolean    @default(true)
  menuItems    MenuItem[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, name])
}

model Variant {
  id              String          @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  variantCategory VariantCategory
  name            String
  menuItems       MenuItemVariant[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([restaurantId, variantCategory, name])
}

model Addon {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  menuItems    MenuItemAddon[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, name])
}

model MenuItem {
  id          String       @id
  restaurantId String
  restaurant  Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name        String
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  menuTypes   MenuType[]
  kotEnabled  Boolean      @default(true)
  cost        Decimal      @db.Decimal(12, 2)
  imageUrl    String?
  status      Boolean      @default(true)
  variants    MenuItemVariant[]
  addons      MenuItemAddon[]
  ingredients MenuItemIngredient[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([restaurantId, name])
}

model MenuItemVariant {
  id          String   @id @default(cuid())
  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  variantId   String
  variant     Variant  @relation(fields: [variantId], references: [id], onDelete: Restrict)
  variantPrice Decimal @db.Decimal(12, 2)

  @@unique([menuItemId, variantId])
}

model MenuItemAddon {
  id         String   @id @default(cuid())
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  addonId    String
  addon      Addon    @relation(fields: [addonId], references: [id], onDelete: Restrict)
  addonsPrice Decimal @db.Decimal(12, 2)
  ingredients MenuItemAddonIngredient[]

  @@unique([menuItemId, addonId])
}

model MenuItemIngredient {
  id              String        @id @default(cuid())
  menuItemId      String
  menuItem        MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  quantity        Decimal       @db.Decimal(12, 4)
  unit            InventoryUnit

  @@unique([menuItemId, inventoryItemId])
}

model MenuItemAddonIngredient {
  id               String        @id @default(cuid())
  menuItemAddonId  String
  menuItemAddon    MenuItemAddon @relation(fields: [menuItemAddonId], references: [id], onDelete: Cascade)
  inventoryItemId  String
  inventoryItem    InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  quantity         Decimal       @db.Decimal(12, 4)
  unit             InventoryUnit

  @@unique([menuItemAddonId, inventoryItemId])
}

model ItemCategory {
  id             String            @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name           String
  subCategories  ItemSubCategory[]
  inventoryItems InventoryItem[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([restaurantId, name])
}

model ItemSubCategory {
  id             String          @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categoryId     String
  category       ItemCategory    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name           String
  inventoryItems InventoryItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([restaurantId, categoryId, name])
}

model Brand {
  id             String          @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name           String
  inventoryItems InventoryItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([restaurantId, name])
}

model InventoryItem {
  id             String          @id
  restaurantId   String
  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name           String
  categoryId     String
  category       ItemCategory    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subCategoryId  String
  subCategory    ItemSubCategory @relation(fields: [subCategoryId], references: [id], onDelete: Restrict)
  brandId        String
  brand          Brand           @relation(fields: [brandId], references: [id], onDelete: Restrict)
  unit           InventoryUnit
  currentStock   Decimal         @default(0) @db.Decimal(14, 4)
  expiryDate     DateTime?
  purchaseItems  PurchaseItem[]
  menuItemIngredients      MenuItemIngredient[]
  menuItemAddonIngredients MenuItemAddonIngredient[]
  inventoryMovements       InventoryMovement[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([restaurantId, name])
}

model Purchase {
  id                  String                  @id @default(cuid())
  restaurantId        String
  restaurant          Restaurant              @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  supplierId          String
  supplier            Supplier                @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  receiveDate         DateTime
  notes               String?
  refNo               String?
  paymentMethod       PurchasePaymentMethod
  restaurantAdminId   String
  restaurantAdmin     User                    @relation("PurchaseCreator", fields: [restaurantAdminId], references: [id], onDelete: Restrict)
  subTotal            Decimal                 @db.Decimal(12, 2)
  items               PurchaseItem[]
  inventoryMovements  InventoryMovement[]
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
}

model PurchaseItem {
  id              String        @id @default(cuid())
  purchaseId      String
  purchase        Purchase      @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  itemName        String
  quantity        Decimal       @db.Decimal(12, 3)
  description     String?
  purchasePrice   Decimal       @db.Decimal(12, 2)
  sellingPrice    Decimal       @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)
  createdAt       DateTime      @default(now())
}

enum OrderStatus {
  COMPLETED
  VOIDED
}

enum OrderPaymentStatus {
  PENDING
  PAID
  CREDIT
}

enum OrderType {
  SALE
  WASTE
}

enum OrderPayMethod {
  CASH
  CARD
  BANK
}

enum BillDiscountType {
  AMOUNT
  PERCENTAGE
}

enum InventoryMovementKind {
  PURCHASE
  ORDER_USE
  VOID_RESTORE
  MANUAL_ADJUST
}

model InventoryMovement {
  id              String                 @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant             @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem          @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  quantityDelta   Decimal                @db.Decimal(14, 4)
  kind            InventoryMovementKind
  description     String
  purchaseId      String?
  purchase        Purchase?              @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  orderId         String?
  order           Order?                 @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt       DateTime               @default(now())
}

model Order {
  id                   String              @id @default(cuid())
  invoiceId            String              @unique
  invoiceDate          DateTime            @default(now())
  restaurantId         String
  restaurant           Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  status               OrderStatus         @default(COMPLETED)
  orderType            OrderType           @default(SALE)
  saleType             MenuType            @default(DINEIN)
  paymentStatus        OrderPaymentStatus
  billTotal            Decimal             @db.Decimal(12, 2)
  billDiscountType     BillDiscountType?
  billDiscountValue    Decimal?            @db.Decimal(12, 2)
  vatAmount            Decimal             @db.Decimal(12, 2)
  serviceChargePercent Decimal             @db.Decimal(6, 2)
  totalAmount          Decimal             @db.Decimal(12, 2)
  returnedAmount       Decimal             @default(0) @db.Decimal(12, 2)
  remarks              String?
  placedByUserId       String
  placedBy             User                @relation("OrderPlacedBy", fields: [placedByUserId], references: [id], onDelete: Restrict)
  receivedByUserId     String
  receivedBy           User                @relation("OrderReceivedBy", fields: [receivedByUserId], references: [id], onDelete: Restrict)
  customerId           String?
  customer             Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  registerId           String?
  register             Register?           @relation(fields: [registerId], references: [id], onDelete: SetNull)
  wasteReason          String?
  wastedAt             DateTime?
  wastedByUserId       String?
  wastedBy             User?               @relation("OrderWastedBy", fields: [wastedByUserId], references: [id], onDelete: SetNull)
  customerName         String?
  customerMobile       String?
  lines                OrderLine[]
  payments             OrderPayment[]
  extraCharges         OrderExtraCharge[]
  inventoryMovements   InventoryMovement[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
}

model Register {
  id                  String                  @id @default(cuid())
  restaurantId        String
  restaurant          Restaurant              @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name                String
  isActive            Boolean                 @default(true)
  occupiedBySessionId String?                 @unique
  occupiedBySession   CashierRegisterSession? @relation("RegisterOccupancy", fields: [occupiedBySessionId], references: [id], onDelete: SetNull)
  sessions            CashierRegisterSession[] @relation("RegisterSessions")
  orders              Order[]
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@unique([restaurantId, name])
}

model CashierRegisterSession {
  id               String    @id @default(cuid())
  restaurantId     String
  restaurant       Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  registerId       String
  register         Register  @relation("RegisterSessions", fields: [registerId], references: [id], onDelete: Cascade)
  cashierUserId    String
  cashier          User      @relation(fields: [cashierUserId], references: [id], onDelete: Cascade)
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  lastHeartbeatAt  DateTime  @default(now())
  occupiedRegister Register? @relation("RegisterOccupancy")

  @@index([restaurantId, cashierUserId, endedAt])
  @@index([restaurantId, registerId, endedAt])
}

model OrderLine {
  id             String          @id @default(cuid())
  orderId        String
  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId     String
  menuItemName   String
  variantId      String?
  variantName    String?
  unitPrice      Decimal         @db.Decimal(12, 2)
  quantity       Decimal         @db.Decimal(12, 3)
  discount       Decimal         @db.Decimal(12, 2)
  netAmount      Decimal         @db.Decimal(12, 2)
  returnedAmount Decimal         @default(0) @db.Decimal(12, 3)
  addons         OrderLineAddon[]
}

model OrderLineAddon {
  id           String    @id @default(cuid())
  orderLineId  String
  orderLine    OrderLine @relation(fields: [orderLineId], references: [id], onDelete: Cascade)
  addonId      String
  addonName    String
  addonPrice   Decimal   @db.Decimal(12, 2)
  quantity     Decimal   @default(1) @db.Decimal(12, 3)
}

model OrderPayment {
  id        String         @id @default(cuid())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method    OrderPayMethod
  amount    Decimal        @db.Decimal(12, 2)
  createdAt DateTime       @default(now())
}

model OrderExtraCharge {
  id      String    @id @default(cuid())
  orderId String
  order   Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reason  String
  amount  Decimal   @db.Decimal(12, 2)
}
